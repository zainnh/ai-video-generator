# Anthropic API key for Claude script generation (prompt mode)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Muapi API key for avatar portrait + lip-sync generation
MUAPI_API_KEY=your_muapi_api_key_here

# Muapi API base URL (default shown below)
MUAPI_BASE_URL=https://api.muapi.ai/api/v1

# Muapi model endpoints (verify with `muapi run <model> --dry-run`)
MUAPI_PORTRAIT_ENDPOINT=flux-schnell-image
MUAPI_LIPSYNC_ENDPOINT=kling-v2-avatar-standard

# Optional: local web UI port (default 5001; avoids macOS AirPlay on 5000)
# WEB_PORT=5001
